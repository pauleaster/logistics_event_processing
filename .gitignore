# .gitignore
# Python bytecode/cache
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Python packaging/build artifacts
build/
dist/
*.egg-info/
.eggs/

# Test/cache output
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/
.tox/
.nox/

# Local environment/secrets
.env
.env.*
!.env.example

# Project-specific external secret files should stay outside repo:
# ~/.oracle/.env
# ~/.rabbitmq/.env

# Logs
*.log
logs/

# Reports generated by the app
reports/*.csv
reports/*.json
reports/*.xlsx
!reports/.gitkeep

# Local data/output generated during development runs
output/
tmp/
temp/

# Oracle/RabbitMQ/Docker local state
oradata/
rabbitmq_data/
docker-data/

# IDE/editor files
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Jupyter notebooks/checkpoints
.ipynb_checkpoints/

# Local SQL*Plus output/spool files
*.lst
*.out
spool/
schema_run.log
seed_run.log
package_run.log

# Do not commit generated credentials or password files
passwords.txt
generated_passwords.txt